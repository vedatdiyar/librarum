{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/ui": [
        "./src/components/ui/index.ts"
      ],
      "@/components/ui/*": [
        "./src/components/ui/*"
      ],
      "@/types": [
        "./src/types/index.ts"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/lib/shared": [
        "./src/lib/shared/index.ts"
      ],
      "@/lib/shared/*": [
        "./src/lib/shared/*"
      ],
      "@/ai": [
        "./src/ai/index.ts"
      ],
      "@/ai/*": [
        "./src/ai/*"
      ],
      "@/db": [
        "./src/db/index.ts"
      ],
      "@/db/*": [
        "./src/db/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
