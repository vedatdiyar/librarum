{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm exec --workspace=@exlibris/web next build -- --webpack",
  "devCommand": "npm run dev --workspace=@exlibris/web",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/ai-suggestions",
      "schedule": "0 9 1 * *"
    }
  ]
}
